# ==========================================================
# nest-starter — Example environment file
# Copia este archivo a `.env` y ajusta los valores.
# ==========================================================

# ----- App -----
NODE_ENV=development
PORT=4000
API_GLOBAL_PREFIX=api

# URL del frontend (para CORS). Coma-separado si son varios.
FRONTEND_URL=http://localhost:5000

# ----- JWT -----
JWT_SECRET=change-me-please-min-32-characters-long
JWT_EXPIRATION=7d

# ----- Database selector -----
# Opciones soportadas: mysql | postgres | sqlite | mongodb
DB_TYPE=mysql

# ----- SQL databases (mysql | postgres) -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=password
DB_NAME=nest_starter

# ----- SQLite -----
# Ruta relativa o absoluta al archivo .sqlite
SQLITE_PATH=./nest-starter.sqlite

# ----- MongoDB -----
# Usado solo cuando DB_TYPE=mongodb
MONGO_URI=mongodb://localhost:27017/nest_starter

# ----- Seeder -----
# Si es 'true' se ejecutan los seeds iniciales al arrancar.
RUN_SEEDS=true
